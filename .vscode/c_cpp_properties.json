{
    "configurations": [
        {
            "name": "x86_64",
            "includePath": [
                "${default}",
                "${workspaceFolder}/include",
                "${workspaceFolder}/arch/x86",
                "${workspaceFolder}/kernel",
                "${workspaceFolder}/drivers",
                "${workspaceFolder}/net",
                "${workspaceFolder}/arch/riscv"
            ],
            "defines": [
                "__x86_64__",
                "__riscv"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64"
        },
        {
            "name": "RISC-V",
            "includePath": [
                "${default}",
                "${workspaceFolder}/include",
                "${workspaceFolder}/arch/riscv",
                "${workspaceFolder}/kernel",
                "${workspaceFolder}/drivers",
                "${workspaceFolder}/net"
            ],
            "defines": [
                "__riscv",
                "__riscv_xlen=64"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}