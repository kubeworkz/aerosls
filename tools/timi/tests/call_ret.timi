; call_ret.timi — exercises CALL/RET and the r0-r7 argument/return
; convention (§4.8) across a per-procedure register frame (§8 Q1).
; Expected result: 42
.entry main
add2:
    ENTER #8
    ADD r0, r0, r1, i32
    RET

main:
    ENTER #8
    LOADI r0, #7, i32
    LOADI r1, #35, i32
    CALL add2
    RET
