; ptr_ops.timi — exercises LEA, PTRADD, and unsigned vs. signed CMP
; relations. LEA/PTRADD never dereference, so a base of address 0 is safe
; here (unlike LOAD/STORE, see mem_ops_native.timi).
; Note: avoids r7 (reserved as the Phase 3 trampoline's scratch pointer).
; Expected result: 125
.entry main
main:
    ENTER #12
    LOADI r0, #0, ptr
    LEA r1, r0, #100          ; r1 = 100
    LOADI r2, #3, i64
    PTRADD r3, r1, r2, i64    ; r3 = r1 + 3*8 = 124
    LOADI r4, #-1, i64        ; all bits set
    LOADI r5, #1, i64
    CMP r6, r4, r5, i64, LT   ; signed: -1 < 1 -> 1
    CMP r8, r4, r5, i64, LTU  ; unsigned: huge < 1 -> 0
    ADD r9, r3, r6, i64       ; 124+1 = 125
    ADD r10, r9, r8, i64      ; 125+0 = 125
    MOV r0, r10, i64
    RET
