; obj_ops.timi — Phase 6 (v0.3): object-typed / ODT-equivalent operations.
;
; Exercises RESOLVE / OBJSIZE / OBJTYPE against the reference
; interpreter's mock object catalog (see timi_interp.c's g_mock_catalog):
;   "timi_add_test2" -> base_vaddr 0x2000, size 303, type PROGRAM(1)
;   "timi_verify3"   -> base_vaddr 0x3000, size 100, type DATA(2)
;   anything else    -> RESOLVE returns 0 (not found)
;
; Expected result: 305
;   r1 = OBJSIZE(RESOLVE("timi_add_test2")) = 303
;   r2 = OBJTYPE(RESOLVE("timi_add_test2")) = 1
;   r5 = 1 if RESOLVE("does_not_exist") == 0 (correctly not found), else 0
;   result = r1 + r2 + r5 = 303 + 1 + 1 = 305

.entry main
main:
    ENTER #8
    RESOLVE r0, "timi_add_test2"
    OBJSIZE r1, r0, u64
    OBJTYPE r2, r0, u64

    RESOLVE r3, "does_not_exist"
    LOADI r4, #0, u64
    CMP r5, r3, r4, u64, EQ

    ADD r6, r1, r2, u64
    ADD r0, r6, r5, u64
    RET
