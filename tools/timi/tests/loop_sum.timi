; loop_sum.timi — CMP/BC loop, sums 1..10. Expected result: 55
.entry main
main:
    ENTER #8
    LOADI r0, #0, i32      ; sum
    LOADI r1, #1, i32      ; i
    LOADI r2, #10, i32     ; limit
    LOADI r4, #1, i32      ; step
loop:
    CMP r3, r1, r2, i32, GT
    BC r3, done
    ADD r0, r0, r1, i32
    ADD r1, r1, r4, i32
    BR loop
done:
    RET
