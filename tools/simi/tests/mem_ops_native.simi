; mem_ops_native.simi — like mem_ops.simi, but uses r7 (the Phase 3
; trampoline's scratch-pointer convention) instead of address 0 as the
; base pointer. Address 0 is a valid offset into the Phase 1 interpreter's
; simulated memory array but is NOT a legitimate address on real hardware —
; see simi_x86.h's documented v1 scope. Expected result: 6912
.entry main
main:
    ENTER #8
    LOADI r1, #1234, i32
    STORE r1, r7, #0, i32
    LOADI r2, #5678, i32
    STORE r2, r7, #8, i32
    LOAD r3, r7, #0, i32
    LOAD r4, r7, #8, i32
    ADD r0, r3, r4, i32
    RET
