; mem_ops.simi — exercises LOAD/STORE against a simulated SLS pointer.
; Expected result: 6912
.entry main
main:
    ENTER #8
    LOADI r0, #0, ptr
    LOADI r1, #1234, i32
    STORE r1, r0, #0, i32
    LOADI r2, #5678, i32
    STORE r2, r0, #4, i32
    LOAD r3, r0, #0, i32
    LOAD r4, r0, #4, i32
    ADD r0, r3, r4, i32
    RET
