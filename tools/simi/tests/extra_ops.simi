; extra_ops.simi — exercises opcodes untouched by the other test programs:
; DIV, MOD, SHL, SHR (logical), SAR (arithmetic), NEG, NOT.
; Note: avoids r7 (reserved as the Phase 3 trampoline's scratch pointer).
; Expected result: -15
.entry main
main:
    ENTER #12
    LOADI r0, #17, i32
    LOADI r1, #5, i32
    DIV r2, r0, r1, i32      ; 17/5 = 3
    MOD r3, r0, r1, i32      ; 17%5 = 2
    ADD r4, r2, r3, i32      ; 5
    SHL r5, r4, #2, i32      ; 5<<2 = 20
    SHR r6, r5, #1, i32      ; 20>>1 = 10 (logical)
    LOADI r8, #-8, i32
    SAR r9, r8, #1, i32      ; -8>>1 arithmetic = -4
    NEG r10, r9, i32         ; -(-4) = 4
    ADD r11, r6, r10, i32    ; 10+4 = 14
    NOT r0, r11, i32         ; ~14 = -15
    RET
